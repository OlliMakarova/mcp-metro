{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "browser": true,
    "es2024": true,
    "jquery": true
  },
  "plugins": ["typescript", "import", "promise", "unicorn", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "off",
    "consistent-return": "off",
    "default-case": "off",
    "global-require": "off",
    "max-classes-per-file": "off",
    "no-nested-ternary": "off",
    "no-param-reassign": "off",
    "no-plusplus": "off",
    "no-shadow": "off",
    "no-underscore-dangle": "off",
    "no-unused-vars": "off",
    "no-use-before-define": "off",
    "no-void": "off",
    "no-await-in-loop": "off",
    "prefer-promise-reject-errors": "off",
    "no-constant-binary-expression": "off",
    "no-control-regex": "off",
    "no-useless-catch": "off",
    "preserve-caught-error": "off",
    "curly": ["error", "all"],
    "prefer-destructuring": ["error", { "object": true, "array": false }],

    "import/first": "off",
    "import/named": "off",
    "import/namespace": "error",
    "import/default": "error",
    "import/export": "error",
    "import/prefer-default-export": "off",
    "import/no-default-export": "error",
    "import/no-unassigned-import": "off",
    "import/no-named-as-default": "off",
    "import/no-named-as-default-member": "off",
    "import/extensions": ["error", "always", { "ts": "never", "js": "always", "ignorePackages": true }],

    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/ban-ts-comment": "off",
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/no-this-alias": "off",
    "@typescript-eslint/no-var-requires": "off",
    "@typescript-eslint/no-unsafe-function-type": "off",
    "@typescript-eslint/no-unsafe-member-access": "off",
    "@typescript-eslint/no-shadow": "error",
    "@typescript-eslint/no-unused-vars": ["error", {
      "args": "after-used",
      "argsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_",
      "vars": "all",
      "varsIgnorePattern": "^_",
      "ignoreRestSiblings": true
    }],

    "unicorn/consistent-function-scoping": "off",
    "unicorn/prefer-set-has": "off",
    "unicorn/no-array-reverse": "off",
    "unicorn/no-array-sort": "off",

    "promise/always-return": "off",
    "promise/no-multiple-resolved": "off"
  },
  "overrides": [
    {
      "files": ["src/index.ts", "src/index.tsx", "index.ts", "index.tsx"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.spec.ts", "**/*.test.tsx", "**/*.spec.tsx"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-unsafe-assignment": "off",
        "@typescript-eslint/no-unsafe-member-access": "off",
        "@typescript-eslint/no-unsafe-call": "off"
      }
    },
    {
      "files": ["bin/**/*.js", "bin/**/*.cjs", "bin/**/*.mjs", "scripts/**/*.js", "scripts/**/*.cjs", "scripts/**/*.mjs"],
      "rules": {
        "@typescript-eslint/no-shadow": "off",
        "no-shadow": "off"
      }
    },
    {
      "files": ["**/jest.config.js", "**/jest.config.cjs", "**/jest.config.mjs", "**/jest-simple-reporter.js", "**/test-cases.js", "**/update.cjs"],
      "rules": {
        "import/no-default-export": "off"
      }
    }
  ],
  "ignorePatterns": [
    "data/**",
    "data-cache/**",
    "node_modules/**",
    "**/dist/**",
    "coverage/**",
    ".claude/**",
    ".idea/**",
    ".run/**",
    "_misc/**",
    "**/_tmp/**",
    "deploy/**",
    "doc/**",
    "migrations/**",
    "**/*.d.ts",
    "**/*.min.js"
  ]
}
