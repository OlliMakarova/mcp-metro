{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "proseWrap": "preserve",
  "ignorePatterns": [
    "data/**",
    "data-cache/**",
    "node_modules/**",
    "**/dist/**",
    "coverage/**",
    ".claude/**",
    ".idea/**",
    ".run/**",
    "_misc/**",
    "**/_tmp/**",
    "deploy/**",
    "doc/**",
    "docs/**",
    "FA-MCP-SDK-DOC/**",
    "readme-docs/**",
    "**/*.md",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml",
    "**/*.html",
    "**/*.css",
    "**/*.lock",
    "yarn.lock",
    "package-lock.json",
    "**/*.min.js",
    "**/*.d.ts"
  ]
}
